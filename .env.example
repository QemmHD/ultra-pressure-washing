# ==========================================
# BACKEND ENVIRONMENT VARIABLES EXAMPLE
# ==========================================
# Rename this file to .env and replace the values with your actual production keys.
# Note: Vite requires environment variables exposed to the client to start with VITE_

# API Configuration (For custom Node/Python backends)
VITE_API_URL=https://api.yourdomain.com/v1

# Supabase Configuration (If using Supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Firebase Configuration (If using Firebase)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Application Config
VITE_ADMIN_EMAIL=admin@ultra.com
VITE_ENABLE_MOCK_DATA=false

# ── Admin Panel Password ──────────────────────────────────────────────────────
# Set this to a strong password. This protects the /admin dashboard.
# IMPORTANT: Never share this file publicly once you add your real password.
VITE_ADMIN_PASSWORD=your-strong-password-here

# ── SMS / Push Notifications (ntfy.sh) ───────────────────────────────────────
# When a customer submits a quote, you get an instant push notification on your phone.
#
# SETUP (5 minutes, completely free):
#   1. Install the "ntfy" app on your phone — search "ntfy" in iOS App Store or Google Play
#   2. Open the app → tap "+" → Subscribe to topic → enter the topic name below
#   3. That's it! You'll get a phone alert every time a quote comes in.
#
# IMPORTANT: Change this to something private (hard to guess). Anyone who knows
# the topic name can subscribe. Use something like: ultrapw-leads-[yourphone-last4]
VITE_NTFY_TOPIC=ultrapw-sevierville-leads